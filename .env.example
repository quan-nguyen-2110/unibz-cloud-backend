PORT=8080
NODE_ENV=development
AWS_REGION=us-east-1

COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# Week 1 local dev (no Cognito): leave pool empty, NODE_ENV=development,
# call protected routes with header X-Dev-User-Id: u_ali

DYNAMO_USERS_TABLE=squadup-users
DYNAMO_PLANS_TABLE=squadup-plans
DYNAMO_TAPINS_TABLE=squadup-tap-ins
DYNAMO_FRIENDS_TABLE=squadup-friendships

S3_AUDIO_BUCKET=squadup-audio

ENABLE_WORKERS=true
LOG_LEVEL=info
